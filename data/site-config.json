    "introduction": {
        "enabled": true,
        "title": "Welcome to EDC",
        "content": [
            "English Development Consultants Co. Ltd. (EDC) is a leading education consulting and teacher recruitment company operating in Thailand. We specialize in connecting qualified educators with prestigious educational institutions across the country.",
            "With years of experience in the education sector, we understand the importance of quality English language education and its impact on future generations. Our mission is to bridge the gap between talented teachers and schools that need them.",
            "We provide comprehensive recruitment services, training programs, and ongoing support to ensure both teachers and educational institutions achieve their goals. Partner with us to transform English language education in Thailand."
        ],
        "image": "images/intro.jpg",
        "imageAlt": "EDC Office or Team"
    },
    "overview": {
        "enabled": true,
        "title": "Company Overview",
        "subtitle": "Our core values drive everything we do",
        "mission": {
            "title": "Our Mission",
            "icon": "🎯",
            "content": "To provide exceptional education consulting services and recruit highly qualified English language teachers to transform the way English is taught in Thailand. We are committed to bridging the gap between education professionals and institutions, ensuring quality education reaches every student."
        },
        "vision": {
            "title": "Our Vision",
            "icon": "👁️",
            "content": "To become the most trusted and respected education consulting company in Thailand and Southeast Asia, recognized for our commitment to educational excellence, teacher development, and creating meaningful connections that shape the future of English language education."
        }
